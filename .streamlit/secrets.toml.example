# Copy this file to .streamlit/secrets.toml and fill in your keys.
# Never commit secrets.toml to version control.

# Streamlit app password (simple gate — personal use only)
APP_PASSWORD = "your-password-here"

# FRED API key — get one free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY = "your-fred-api-key-here"

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY = "your-anthropic-api-key-here"

# Supabase — https://supabase.com (project Settings → API Keys)
SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY = "sb_secret_your-secret-key-here"

# Local dev only — email used when st.user is not available (localhost)
DEV_USER_EMAIL = "you@example.com"
